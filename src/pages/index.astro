---
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
import LinkedInIcon from "../components/icons/LinkedIn.astro";
import SocialPill from "../components/SocialPill.astro";
import GithubIcon from "../components/icons/GitHub.astro";
import MailIcon from "../components/icons/Mail.astro";
import SectionContainer from "../components/SectionContainer.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import AboutMe from "../components/AboutMe.astro";
import Skills from "../components/Skills.astro";
import Briefcase from "../components/icons/Briefcase.astro";
import CodeIcon from "../components/icons/Code.astro";
import ProfileCheck from "../components/icons/ProfileCheck.astro";
---

<Layout
  title="Portfolio de Javi Paez - Desarrollador Web Full Stack & IA Entusiasta"
  description="Desarrollador Full Stack en Canary Options SL (IAbot.io). Especializado en React, Next.js, Astro y Supabase. Descubre mis proyectos y trayectoria profesional."
>
  <main class="px-4">
    <SectionContainer id="hero" class="py-16 md:py-36 pb-32">
      <div class="flex gap-4 mb-4 items-center">
        <img
          class="rounded-full shadow-lg size-16 object-cover border-2 border-white/10"
          src="/javi-paez.jpg"
          alt="Javi Paez photo"
        />
        <a
          href="https://linkedin.com/in/javipaez"
          target="_blank"
          rel="noopener"
          class="flex items-center transition md:justify-center md:hover:scale-105"
        >
          <Badge>Disponible para trabajar</Badge>
        </a>
      </div>
      <h1
        class="text-4xl font-bold tracking-tight text-gray-200 sm:text-5xl bg-clip-text text-transparent bg-gradient-to-r from-white via-white to-yellow-200/50"
      >
        Hey, soy Javi Paez
      </h1>
      <p
        class="mt-6 text-xl text-gray-300 [&>strong]:text-yellow-200 [&>strong]:font-semibold text-pretty"
      >
        +2 años de experiencia. <strong>Desarrollador Full Stack</strong> en <span class="text-yellow-200/90">Canary Options SL (IAbot.io)</span>. Especializado en crear aplicaciones únicas, funcionales y escalables.
      </p>

      <Skills />

      <nav class="flex flex-wrap gap-4 mt-8">
        <SocialPill href="https://linkedin.com/in/javipaez">
          <LinkedInIcon class="size-4" />
          LinkedIn
        </SocialPill>
        <SocialPill href="https://github.com/JaviPaez7">
          <GithubIcon class="size-4" />
          GitHub
        </SocialPill>
        <SocialPill href="mailto:javipaeztoledo@gmail.com">
          <MailIcon class="size-4" />
          javipaeztoledo@gmail.com
        </SocialPill>
        <SocialPill href="/CV_Javi_Paez.pdf" download="CV_Javi_Paez.pdf">
          <svg class="size-4" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2" /><path d="M7 11l5 5l5 -5" /><path d="M12 4l0 12" /></svg>
          Descargar CV
        </SocialPill>
      </nav>
    </SectionContainer>

    <div class="space-y-24">
      <SectionContainer id="experiencia" class="reveal">
        <h2
          class="flex items-center mb-6 text-3xl font-semibold gap-x-3 text-white"
        >
          <Briefcase class="size-8" />
          Experiencia laboral
        </h2>
        <Experience />
      </SectionContainer>

      <SectionContainer id="proyectos" class="reveal">
        <h2
          class="flex items-center mb-6 text-3xl font-semibold gap-x-3 text-white"
        >
          <CodeIcon class="size-7" />
          Proyectos
        </h2>
        <Projects />
      </SectionContainer>

      <SectionContainer id="sobre-mi" class="reveal">
        <h2
          class="flex items-center mb-6 text-3xl font-semibold gap-x-3 text-white"
        >
          <ProfileCheck class="size-8" />
          Sobre mí
        </h2>
        <AboutMe />
      </SectionContainer>
    </div>
  </main>
</Layout>
